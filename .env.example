# Where the widget iframe is loaded from. Defaults to the prod widget in code,
# so this is optional. Override for staging/local.
NEXT_PUBLIC_WIDGET_ORIGIN=https://sdk-widget.vercel.app

# Optional RPC keys (NEXT_PUBLIC_ → shipped to the browser; use demo-tier keys).
# Without them the widget falls back to public RPCs (may rate-limit).
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_ANKR_API_KEY=
NEXT_PUBLIC_WC_PROJECT_ID=
